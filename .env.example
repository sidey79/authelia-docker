TZ=Europe/Berlin
BASE_STACK_DATA_PATH=/opt/docker/authelia
AUTHELIA_UID=1007
AUTHELIA_GID=1007

POSTGRES_DB=authelia
POSTGRES_USER=authelia

# Secrets are file-based via bind mount:
# ${BASE_STACK_DATA_PATH}/secrets -> /run/authelia-secrets (read-only in containers)
# Required files:
# - reset_password_jwt_secret
# - session_secret
# - storage_encryption_key
# - postgres_password

# SMTP relay integration (https://github.com/sidey79/smtp-relay-docker)
AUTHELIA_NOTIFIER_SMTP_ADDRESS=smtp://smtp-relay:25
AUTHELIA_NOTIFIER_SMTP_SENDER=noreply@example.com
