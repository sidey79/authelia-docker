TZ=Europe/Berlin
BASE_STACK_DATA_PATH=/opt/docker/authelia

POSTGRES_DB=authelia
POSTGRES_USER=authelia
POSTGRES_PASSWORD=replace-with-strong-postgres-password

# Authelia secrets/config via environment variables (no docker secrets)
AUTHELIA_IDENTITY_VALIDATION__RESET_PASSWORD__JWT_SECRET=replace-with-strong-random-jwt-secret
AUTHELIA_SESSION__SECRET=replace-with-strong-random-session-secret
AUTHELIA_STORAGE__ENCRYPTION_KEY=replace-with-strong-random-encryption-key
AUTHELIA_STORAGE__POSTGRES__PASSWORD=replace-with-strong-postgres-password

# SMTP relay integration (https://github.com/sidey79/smtp-relay-docker)
AUTHELIA_NOTIFIER__SMTP__ADDRESS=submission://smtp-relay:25
AUTHELIA_NOTIFIER__SMTP__SENDER=noreply@example.com
